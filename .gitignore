# Byte-compiled / optimized / DLL files
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter Notebooks
.ipynb_checkpoints/

# Virtual environments
venv/
env/
.env

# Large archives and binaries
*.zip
*.tar.gz
*.tgz

# IDE files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Fake News Detector - Data and Models (Keep it professional and lightweight)
# We ignore the raw dataset CSVs (each 50MB+) and full fp32 PyTorch checkpoints.
# The quantized_model.pt (132MB) is tracked via Git LFS instead.
backend/data/raw/
backend/data/**/*.csv
backend/dataset/
backend/dataset/**/*.csv
backend/models/saved/*.safetensors
backend/models/saved/pytorch_model.bin
backend/models/training_output/
backend/models/test_data.csv
# Allow quantized weights and marker (tracked via Git LFS)
!backend/models/saved/quantized_model.pt
!backend/models/saved/quantized.flag
!backend/models/saved/config.json
!backend/models/saved/tokenizer.json
!backend/models/saved/tokenizer_config.json
!backend/models/saved/special_tokens_map.json
!backend/models/saved/vocab.txt

# Output logs and temporary images
*.log
backend/models/confusion_matrix.png
